SOMNIA_RPC_URL=https://your-somnia-rpc
SOMNIA_CHAIN_ID=50312
# One line: 64 hex chars, usually with 0x prefix (prefix added automatically if omitted).
# No spaces, quotes, or trailing newline after the key.
SOMNIA_PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# Reactivity subscription gas settings (gwei strings, passed to viem parseGwei)
# REACTIVITY_MAX_FEE_GWEI must be > 0 — if you set 0, the SDK falls back to 10 (Somnia base fee ~6 gwei).
REACTIVITY_PRIORITY_FEE_GWEI=0
REACTIVITY_MAX_FEE_GWEI=10
REACTIVITY_GAS_LIMIT=3000000
SCHEDULE_DELAY_MS=90000
