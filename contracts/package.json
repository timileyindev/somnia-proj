{
  "name": "@somnia-autopilot/contracts",
  "private": true,
  "version": "0.1.0",
  "description": "Solidity contracts and scripts for Somnia Autopilot",
  "main": "index.js",
  "scripts": {
    "clean": "hardhat clean",
    "compile": "hardhat compile",
    "typecheck": "tsc --noEmit",
    "lint": "npm run typecheck",
    "test": "hardhat test",
    "deploy": "hardhat run scripts/deploy.ts --network somniaTestnet",
    "deploy:local": "hardhat run scripts/deploy.ts --network hardhatMainnet",
    "setup:subscriptions": "hardhat run scripts/setupSubscriptions.ts --network somniaTestnet",
    "demo:seed": "hardhat run scripts/seedDemoData.ts --network somniaTestnet",
    "demo:trigger": "hardhat run scripts/triggerDemo.ts --network somniaTestnet",
    "sync:vite-env": "hardhat run scripts/emitViteEnv.ts --network hardhatMainnet",
    "sync:vite-env:write": "hardhat run scripts/emitViteEnv.ts --network hardhatMainnet -- --write"
  },
  "keywords": [
    "somnia",
    "reactivity",
    "automation",
    "orchestration"
  ],
  "license": "MIT",
  "type": "module",
  "devDependencies": {
    "@nomicfoundation/hardhat-ignition": "^3.1.0",
    "@nomicfoundation/hardhat-ignition-viem": "^3.1.0",
    "@nomicfoundation/hardhat-keystore": "^3.0.5",
    "@nomicfoundation/hardhat-network-helpers": "^3.0.4",
    "@nomicfoundation/hardhat-node-test-runner": "^3.0.12",
    "@nomicfoundation/hardhat-toolbox": "^7.0.0",
    "@nomicfoundation/hardhat-toolbox-viem": "^5.0.3",
    "@nomicfoundation/hardhat-verify": "^3.0.12",
    "@nomicfoundation/hardhat-viem": "^3.0.4",
    "@nomicfoundation/hardhat-viem-assertions": "^3.0.7",
    "@nomicfoundation/ignition-core": "^3.1.0",
    "@types/node": "^22.19.15",
    "dotenv": "^17.3.1",
    "forge-std": "github:foundry-rs/forge-std#v1.9.4",
    "hardhat": "^3.2.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.8.0",
    "viem": "^2.47.6"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1",
    "@somnia-autopilot/sdk": "*",
    "@somnia-chain/reactivity": "^0.1.10",
    "@somnia-chain/reactivity-contracts": "^0.1.6",
    "ethers": "^6.16.0"
  }
}
